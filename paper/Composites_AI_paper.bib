}

@inproceedings{shinoura_process_2023-1,
	address = {Fukuoka City, Japan},
	title = {Process simulation and mechanical testing of sheet molding compound products},
	url = {http://aip.scitation.org/doi/abs/10.1063/5.0168232},
	doi = {10.1063/5.0168232},
	abstract = {Sheet molding compound (SMC) is widely used for compression process of fiber reinforced plastics. In SMC molding process, the material is put on a heated mold, compressed and shaped into a product. The main advantage of SMC product is the low cycle time of the compression molding process. Moreover, it allows shaping of complex geometries like ribs and bosses. However, the fiber orientation varies widely due to the flow behavior in the compression molding. Therefore, it is important to predict and design the fiber orientation to obtain the SMC products which have desired characteristics. In this paper, firstly, a variety of SMC products were predicted using process simulations. The simulation results showed that changing the initial charge pattern of SMC material varied the fiber orientation of the products. Secondly, SMC products of three different charge patterns were molded with the same conditions as the process simulation. Test specimens were cut out from the products and tensile tests were conducted. The tensile testing results showed correlations between orientation and properties, that are specimens predicted aligned fiber orientation showed higher values of mechanical properties, on the other hand specimens predicted lower fiber orientation showed lower values. The specimens were divided into three pieces in the tensile direction, and the fiber orientations were identified with X-ray diffraction which reflected the graphite crystallites in the carbon fibers. The fiber orientations were compared with the simulation results, and the comparisons showed reasonable correlations. As written above, the relation between fiber orientation and mechanical properties of SMC was identified. Therefore, this method enables us to design SMC products with desired characteristics.},
	language = {en},
	urldate = {2025-11-11},
	author = {Shinoura, Yasutaka and Ishikawa, Takeshi and Kobayashi, Takayuki and Miyauchi, Takuya and Sugawara, Hirotaka},
	year = {2023},
	pages = {050010},
	file = {Shinoura et al. - 2023 - Process simulation and mechanical testing of sheet.pdf:/Users/flore/Zotero/storage/L53NU8DD/Shinoura et al. - 2023 - Process simulation and mechanical testing of sheet.pdf:application/pdf},
}

@article{mahe_revisited_2023-1,
	title = {A revisited compression flow model for concentrated suspensions with fiber-friction interactions},
	volume = {319},
	issn = {03770257},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0377025723001027},
	doi = {10.1016/j.jnnfm.2023.105090},
	abstract = {Sheet Molding Compounds are composite materials made of chopped fiber bundles and thermoset resin pro­ cessed by compression molding. Their high fiber content and relatively long fiber length classify them as concentrated suspensions. Experimental observations of mesostructures indicate the importance of contacts between the fiber bundles and friction forces during processing of these materials. They also reveal the presence of highly entangled networks of fiber bundles. Hence current models based on Jeffery’s equation and the sus­ pension theory are not able to predict the fiber orientation during flow and capture the rheological response during the compression of the suspension. A friction-based continuum model is proposed to describe the deformation of SMC mesostructures and their kinematics as a function of the fiber orientation tensor. An experimental study using tailored SMC materials confirm the rheological dependence of SMC materials on their mesostructures properties and validate the proposed friction model. The two material parameters of the model are identified experimentally and the results are discussed.},
	language = {en},
	urldate = {2025-11-11},
	journal = {Journal of Non-Newtonian Fluid Mechanics},
	author = {Mahé, François and Binetruy, Christophe and Advani, Suresh and Férec, Julien and Eck, Benedikt},
	month = sep,
	year = {2023},
	pages = {105090},
	file = {Mahé et al. - 2023 - A revisited compression flow model for concentrate.pdf:/Users/flore/Zotero/storage/8QPZB5EF/Mahé et al. - 2023 - A revisited compression flow model for concentrate.pdf:application/pdf},
}

@article{schommer_polarization_2023-1,
	title = {Polarization imaging for surface fiber orientation measurements of carbon fiber sheet molding compounds},
	volume = {37},
	issn = {24522139},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S2452213922003989},
	doi = {10.1016/j.coco.2022.101456},
	abstract = {The ability to measure the fiber orientation in fiber reinforced polymers plays a vital role in process and part design. Recently, it has been discovered that carbon fibers polarize light, providing an opportunity to detect the fiber orientation in carbon fiber-reinforced polymer parts. The Fraunhofer Institute for Integrated Circuits has developed a polarization camera system capable of measuring the polarization state of light reflected from ob­ jects in real-time. In this work, the camera system is used to measure the surface fiber orientation in carbon fiber reinforced Sheet Molding Compound semi-finished products at several stages of the processing chain. First, the fiber orientation of carbon fiber-reinforced Sheet Molding Compound semi-finished product is measured during continuous production, enabling real-time quality control and complete digitization of the material’s fiber orientation information. Second, the measurement system is used to characterize static flat pressed carbon fiber reinforced Sheet Molding Compound specimens. In addition, the technique is widely applicable to many other carbon fiber based raw material forms (e.g. preforms, prepregs, tapes) and even composite parts.},
	language = {en},
