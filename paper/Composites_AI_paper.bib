	file = {Anagnostou et al. - 2018 - Hierarchical micromechanical modeling of the visco.pdf:/Users/flore/Zotero/storage/BJCVARDC/Anagnostou et al. - 2018 - Hierarchical micromechanical modeling of the visco.pdf:application/pdf},
}

