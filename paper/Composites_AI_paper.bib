}

@article{teuwsen_direct_2020,
	title = {Direct {Fiber} {Simulation} of a {Compression} {Molded} {Ribbed} {Structure} {Made} of a {Sheet} {Molding} {Compound} with {Randomly} {Oriented} {Carbon}/{Epoxy} {Prepreg} {Strands}—{A} {Comparison} of {Predicted} {Fiber} {Orientations} with {Computed} {Tomography} {Analyses}},
	volume = {4},
	issn = {2504-477X},
	url = {https://www.mdpi.com/2504-477X/4/4/164},
	doi = {10.3390/jcs4040164},
	abstract = {Discontinuous ﬁber composites (DFC) such as carbon ﬁber sheet molding compounds (CF-SMC) are increasingly used in the automotive industry for manufacturing lightweight parts. Due to the ﬂow conditions during compression molding of complex geometries, a locally varying ﬁber orientation evolves. Knowing these process-induced ﬁber orientations is key to a proper part design since the mechanical properties of the ﬁnal part highly depend on its local microstructure. Local ﬁber orientations can be measured and analyzed by means of micro-computed tomography (µCT) and digital image processing, or predicted by process simulation. This paper presents a detailed comparison of numerical and experimental analyses of compression molded ribbed hat proﬁle parts made of CF-SMC with 50 mm long randomly oriented strands (ROS) of chopped unidirectional (UD) carbon/epoxy prepreg tape. X-ray µCT scans of three entire CF-SMC parts are analyzed to compare determined orientation tensors with those coming from a direct ﬁber simulation (DFS) tool featuring a novel strand generation approach, realistically mimicking the initial ROS charge mesostructure. The DFS results show an overall good agreement of predicted local ﬁber orientations with µCT measurements, and are therefore precious information that can be used in subsequent integrative simulations to determine the part’s mesostructure-related anisotropic behavior under mechanical loads.},
	language = {en},
	number = {4},
	urldate = {2025-11-14},
	journal = {Journal of Composites Science},
	author = {Teuwsen, Jan and Hohn, Stephan K. and Osswald, Tim A.},
	month = oct,
	year = {2020},
	pages = {164},
	file = {Teuwsen et al. - 2020 - Direct Fiber Simulation of a Compression Molded Ri.pdf:/Users/flore/Zotero/storage/4XXWZ32X/Teuwsen et al. - 2020 - Direct Fiber Simulation of a Compression Molded Ri.pdf:application/pdf},
}

@inproceedings{shinoura_process_2023,
	address = {Fukuoka City, Japan},
	title = {Process simulation and mechanical testing of sheet molding compound products},
	url = {http://aip.scitation.org/doi/abs/10.1063/5.0168232},
	doi = {10.1063/5.0168232},
	abstract = {Sheet molding compound (SMC) is widely used for compression process of fiber reinforced plastics. In SMC molding process, the material is put on a heated mold, compressed and shaped into a product. The main advantage of SMC product is the low cycle time of the compression molding process. Moreover, it allows shaping of complex geometries like ribs and bosses. However, the fiber orientation varies widely due to the flow behavior in the compression molding. Therefore, it is important to predict and design the fiber orientation to obtain the SMC products which have desired characteristics. In this paper, firstly, a variety of SMC products were predicted using process simulations. The simulation results showed that changing the initial charge pattern of SMC material varied the fiber orientation of the products. Secondly, SMC products of three different charge patterns were molded with the same conditions as the process simulation. Test specimens were cut out from the products and tensile tests were conducted. The tensile testing results showed correlations between orientation and properties, that are specimens predicted aligned fiber orientation showed higher values of mechanical properties, on the other hand specimens predicted lower fiber orientation showed lower values. The specimens were divided into three pieces in the tensile direction, and the fiber orientations were identified with X-ray diffraction which reflected the graphite crystallites in the carbon fibers. The fiber orientations were compared with the simulation results, and the comparisons showed reasonable correlations. As written above, the relation between fiber orientation and mechanical properties of SMC was identified. Therefore, this method enables us to design SMC products with desired characteristics.},
	language = {en},
	urldate = {2025-11-14},
	author = {Shinoura, Yasutaka and Ishikawa, Takeshi and Kobayashi, Takayuki and Miyauchi, Takuya and Sugawara, Hirotaka},
	year = {2023},
	pages = {050010},
	file = {Shinoura et al. - 2023 - Process simulation and mechanical testing of sheet.pdf:/Users/flore/Zotero/storage/7BSYXEKU/Shinoura et al. - 2023 - Process simulation and mechanical testing of sheet.pdf:application/pdf},
}

@article{bretz_non-destructive_2021,
	title = {Non-destructive measurement of fiber mass content of glass fiber sheet molding compound using {Terahertz} radiation},
	volume = {168},
	issn = {02632241},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S0263224120309222},
	doi = {10.1016/j.measurement.2020.108386},
	abstract = {Sheet Molding Compounds (SMC), a type of fiber-reinforced polymers, are popular lightweight material due to their handling and processability. The fiber mass content (FMC) as well as the fiber orientation distribution determine mechanical properties of manufactured components. However, local deviations from the intended FMC occur during the production of the semi-finished material as well as during the molding itself. In this contribution, SMC was investigated regarding its properties in the Terahertz (THz) spectrum to non-destructively quantify the local FMC. SMC with different FMC between 38 and 54 wt\% was industrially produced and dry glass fibers were added to further increase the glass fiber content. Reference measurements of the FMC were conducted via thermogravimetric analysis and showed a mean deviation from the intended FMC of 2.64 wt\%. The peak arrival time, the transmitted energy and the refractive index of the THz signal were determined and assessed regarding their correlation with the FMC. A multivariate regression analysis including backward elimination led to a low bias statistical model between the refractive index and the FMC with a cross-validated root mean square error (RMSE) of 1.33 wt\%.},
	language = {en},
	urldate = {2025-11-14},
	journal = {Measurement},
	author = {Bretz, Lucas and Häfner, Benjamin and Lanza, Gisela},
	month = jan,
	year = {2021},
	pages = {108386},
	file = {Bretz et al. - 2021 - Non-destructive measurement of fiber mass content .pdf:/Users/flore/Zotero/storage/GRVMC6KP/Bretz et al. - 2021 - Non-destructive measurement of fiber mass content .pdf:application/pdf},
}

@inproceedings{gall_sheet_2025,
