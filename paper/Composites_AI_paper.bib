	pages = {497--506},
	file = {Gall - 2025 - Sheet Molding Compound with highly aligned fiber r.pdf:/Users/flore/Zotero/storage/LF2I4Z2Z/Gall - 2025 - Sheet Molding Compound with highly aligned fiber r.pdf:application/pdf},
}

