}

@article{meyer_direct_2020,
	title = {Direct {Bundle} {Simulation} approach for the compression molding process of {Sheet} {Molding} {Compound}},
	volume = {132},
	issn = {1359835X},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S1359835X20300476},
	doi = {10.1016/j.compositesa.2020.105809},
	abstract = {The manufacturing process of Sheet Molding Compounds (SMC) induces a reorientation of fibers during the flow, which influences local properties and is of interest for structural computations. Typically, the reorientation is described with an evolution equation for the second order fiber orientation tensor, which requires a closure approximation and multiple empirical parameters to describe long fibers. However, CT scans of SMC microstructures show that fiber bundles stay mostly intact during molding. Treating hundreds of fibers in such a bundle as one instance enables direct simulation on component scale. This work proposes a direct simulation approach, in which bundle segments experience Stokes’ drag forces and opposing forces are applied to the fluid field. The method is applied to specimens with a double-curved geometry and compared to CT scans. The Direct Bundle Simulation provides increased accuracy of fiber orientations and enables prediction of fiber-matrix separation with affordable computational effort at component scale.},
	language = {en},
	urldate = {2025-12-11},
	journal = {Composites Part A: Applied Science and Manufacturing},
	author = {Meyer, N. and Schöttl, L. and Bretz, L. and Hrymak, A.N. and Kärger, L.},
	month = may,
	year = {2020},
	pages = {105809},
	file = {Meyer et al. - 2020 - Direct Bundle Simulation approach for the compress.pdf:/Users/flore/Zotero/storage/XAPU65B7/Meyer et al. - 2020 - Direct Bundle Simulation approach for the compress.pdf:application/pdf},
}

