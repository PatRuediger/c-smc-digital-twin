	issn = {13598368},
	url = {https://linkinghub.elsevier.com/retrieve/pii/S135983682100576X},
	doi = {10.1016/j.compositesb.2021.109198},
	abstract = {Continuous carbon fiber prepreg slit and cut into rectangular platelets has proven to be a useful material for net shape molding of semi-structural and structural components in the aerospace and automotive industries. To assist the designer in use of these prepreg platelet molding compounds, sometimes called carbon fiber sheet molding compounds, simulation tools are required that can predict the as-manufactured fiber orientation state which has a significant impact on the resulting performance. Herein, an analysis workflow for design-enabling predictions is demonstrated for a double dome geometry with two different initial charge configurations. The workflow is validated through comparison with experimental short shots, orientation state, and stiffness trends. Significantly, to complete the validation, a method is proposed for determining the confidence bounds on measured orientation state enhancing the results of optical microscopy which can only produce a small sample of platelet orientations.},
